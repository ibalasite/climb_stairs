# Ladder Room Online — Environment Variables
# Copy this file to .env and fill in the actual values
# NEVER commit .env to version control

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
METRICS_PORT=8080

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=21600
JWT_CLOCK_SKEW_SECONDS=30

# ─── Room Settings ───────────────────────────────────────────────────────────
ROOM_TTL_SECONDS=86400
ROOM_IDLE_EXPIRE_SECONDS=300
MAX_PLAYERS_PER_ROOM=50

# ─── WebSocket ───────────────────────────────────────────────────────────────
WS_MAX_PAYLOAD_BYTES=65536
WS_RATE_LIMIT_PER_MIN=60

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
